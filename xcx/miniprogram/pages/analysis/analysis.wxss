.container {
  padding-bottom: 140rpx;
}

.config-card {
  display: flex;
  flex-direction: column;
  gap: 40rpx;
  padding: 40rpx 32rpx;
}

.config-item {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.config-label {
  font-size: 30rpx;
  color: var(--text-secondary);
  font-weight: 500;
}

.config-value {
  font-size: 34rpx;
  font-weight: 700;
  color: var(--text-main);
  background: #F8FAFC;
  padding: 20rpx 24rpx;
  border-radius: 12rpx;
}

.radio-group {
  display: flex;
  gap: 48rpx;
  background: #F8FAFC;
  padding: 24rpx;
  border-radius: 12rpx;
}

.radio-label {
  display: flex;
  align-items: center;
  font-size: 30rpx;
  color: var(--text-main);
  font-weight: 500;
}

.radio-label radio {
  transform: scale(0.85);
  margin-right: 8rpx;
}

.compare-input {
  height: 88rpx;
  background-color: #F8FAFC;
  border-radius: 12rpx;
  padding: 0 32rpx;
  font-size: 30rpx;
  border: 2rpx solid transparent;
  transition: all 0.3s;
}

.compare-input:focus {
  background-color: #fff;
  border-color: var(--primary-color);
  box-shadow: 0 0 0 4rpx rgba(255, 140, 0, 0.1);
}

.preview-card {
  min-height: 300rpx;
  padding: 40rpx 32rpx;
}

.upload-card {
  padding: 40rpx 32rpx;
}

.upload-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  gap: 24rpx;
  margin-bottom: 24rpx;
}

.upload-title {
  font-size: 32rpx;
  font-weight: 700;
  color: var(--text-main);
  margin-bottom: 8rpx;
}

.upload-subtitle {
  font-size: 24rpx;
  color: var(--text-muted);
  line-height: 1.5;
}

.upload-count {
  font-size: 24rpx;
  color: var(--warning-color);
  background: #FFF4F1;
  border-radius: 999rpx;
  padding: 10rpx 20rpx;
  white-space: nowrap;
}

.upload-count.ready {
  color: var(--success-color);
  background: var(--success-light);
}

.upload-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  margin-bottom: 24rpx;
}

.upload-file-item,
.upload-empty {
  background: #F8FAFC;
  border-radius: 16rpx;
  padding: 20rpx 24rpx;
}

.upload-file-name {
  font-size: 28rpx;
  color: var(--text-main);
  word-break: break-all;
}

.upload-empty {
  text-align: center;
  color: var(--text-muted);
  font-size: 26rpx;
  margin-bottom: 24rpx;
}

.upload-entry-btn {
  height: 80rpx;
  line-height: 80rpx;
  border-radius: 40rpx;
  background: #FFF6EC;
  color: var(--primary-color);
  font-size: 30rpx;
  font-weight: 600;
  border: 2rpx solid rgba(255, 140, 0, 0.18);
}

.upload-entry-btn::after {
  border: none;
}

.loading-wrap, .empty-preview {
  height: 240rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: var(--text-muted);
  font-size: 28rpx;
  background: #F8FAFC;
  border-radius: 16rpx;
  margin-top: 20rpx;
}

.preview-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 32rpx;
  padding-bottom: 24rpx;
  border-bottom: 2rpx dashed #F0F2F5;
}

.provider-tag {
  font-size: 26rpx;
  color: var(--primary-color);
  background: var(--primary-light);
  padding: 6rpx 20rpx;
  border-radius: 12rpx;
  font-weight: 600;
}

.version-text {
  font-size: 24rpx;
  color: var(--text-muted);
  font-family: monospace;
}

.preview-summary {
  font-size: 30rpx;
  color: var(--text-main);
  line-height: 1.6;
  margin-bottom: 32rpx;
  background-color: #F8FAFC;
  padding: 32rpx;
  border-radius: 16rpx;
  letter-spacing: 1rpx;
}

.preview-metrics {
  display: flex;
  gap: 24rpx;
}

.p-metric {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  background-color: #F8FAFC;
  padding: 24rpx;
  border-radius: 16rpx;
  transition: transform 0.3s;
}

.p-metric:active {
  transform: scale(0.98);
}

.p-label {
  font-size: 26rpx;
  color: var(--text-secondary);
  margin-bottom: 12rpx;
  font-weight: 500;
}

.p-value {
  font-size: 36rpx;
  font-weight: 700;
  color: var(--primary-color);
  font-family: 'DIN Alternate', sans-serif;
}

.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  height: 140rpx;
  background-color: rgba(255, 255, 255, 0.95);
  backdrop-filter: blur(10px);
  display: flex;
  align-items: center;
  padding: 0 40rpx;
  box-shadow: 0 -4rpx 24rpx rgba(0, 0, 0, 0.06);
  z-index: 100;
  padding-bottom: env(safe-area-inset-bottom);
}

.btn-primary {
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  background: var(--primary-gradient);
  color: #fff;
  border-radius: 44rpx;
  font-size: 34rpx;
  font-weight: 600;
  text-align: center;
  box-shadow: 0 8rpx 20rpx rgba(255, 140, 0, 0.3);
  transition: all 0.3s;
}

.btn-primary:active:not(.disabled) {
  transform: scale(0.98);
  box-shadow: 0 4rpx 10rpx rgba(255, 140, 0, 0.2);
}

.btn-primary.disabled {
  background: #E2E8F0;
  color: #94A3B8;
  box-shadow: none;
}

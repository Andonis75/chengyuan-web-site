.analyzing-page {
  padding-top: 24rpx;
  padding-bottom: 60rpx;
}

.hero-card {
  padding: 40rpx 32rpx 48rpx;
  background: linear-gradient(180deg, #FFF8F0 0%, #FFFFFF 100%);
}

.hero-top {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  gap: 24rpx;
  margin-bottom: 32rpx;
}

.hero-title {
  font-size: 42rpx;
  font-weight: 800;
  color: var(--text-main);
  margin-bottom: 10rpx;
}

.hero-subtitle {
  font-size: 26rpx;
  color: var(--text-muted);
}

.hero-tag {
  font-size: 24rpx;
  color: var(--primary-color);
  background: var(--primary-light);
  border-radius: 999rpx;
  padding: 10rpx 20rpx;
}

.animation-wrap {
  position: relative;
  height: 280rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.pulse {
  position: absolute;
  border-radius: 50%;
  border: 2rpx solid rgba(255, 140, 0, 0.2);
  animation: pulse-ring 2.4s ease-out infinite;
}

.pulse-outer {
  width: 220rpx;
  height: 220rpx;
}

.pulse-inner {
  width: 150rpx;
  height: 150rpx;
  animation-delay: 0.6s;
}

.core-orb {
  width: 104rpx;
  height: 104rpx;
  border-radius: 52rpx;
  background: var(--primary-gradient);
  color: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 44rpx;
  font-weight: 800;
  box-shadow: 0 12rpx 28rpx rgba(255, 140, 0, 0.28);
  animation: float-orb 1.8s ease-in-out infinite;
}

.progress-row {
  display: flex;
  align-items: center;
  gap: 20rpx;
  margin-bottom: 20rpx;
}

.progress-track {
  flex: 1;
  height: 18rpx;
  background: #F2F4F7;
  border-radius: 999rpx;
  overflow: hidden;
}

.progress-fill {
  height: 100%;
  border-radius: 999rpx;
  background: var(--primary-gradient);
  transition: width 0.6s ease;
}

.progress-value {
  width: 88rpx;
  text-align: right;
  font-size: 28rpx;
  font-weight: 700;
  color: var(--primary-color);
}

.status-text {
  text-align: center;
  font-size: 28rpx;
  color: var(--text-secondary);
  line-height: 1.6;
}

.step-card {
  padding: 32rpx;
}

.step-title,
.fail-title {
  font-size: 32rpx;
  font-weight: 700;
  color: var(--text-main);
  margin-bottom: 20rpx;
}

.step-list {
  display: flex;
  flex-direction: column;
  gap: 22rpx;
}

.step-item {
  display: flex;
  align-items: center;
}

.step-dot {
  width: 22rpx;
  height: 22rpx;
  border-radius: 11rpx;
  background: #D7DEE7;
  margin-right: 20rpx;
}

.step-dot.done {
  background: var(--primary-color);
  box-shadow: 0 0 0 8rpx rgba(255, 140, 0, 0.12);
}

.step-label {
  font-size: 28rpx;
  color: var(--text-muted);
}

.step-label.done {
  color: var(--text-main);
  font-weight: 600;
}

.fail-card {
  padding: 40rpx 32rpx;
}

.fail-text {
  font-size: 28rpx;
  color: var(--text-secondary);
  line-height: 1.7;
  margin-bottom: 28rpx;
}

.retry-btn {
  height: 80rpx;
  line-height: 80rpx;
  border-radius: 40rpx;
  background: var(--primary-gradient);
  color: #fff;
  font-size: 30rpx;
  font-weight: 600;
}

.retry-btn::after {
  border: none;
}

@keyframes pulse-ring {
  0% {
    transform: scale(0.88);
    opacity: 0.85;
  }

  100% {
    transform: scale(1.08);
    opacity: 0;
  }
}

@keyframes float-orb {
  0%,
  100% {
    transform: translateY(0);
  }

  50% {
    transform: translateY(-10rpx);
  }
}


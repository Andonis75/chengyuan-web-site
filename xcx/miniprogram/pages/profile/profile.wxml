<view class="container">
  <!-- 用户信息卡片 -->
  <view class="user-card">
    <view class="avatar-wrap">
      <image class="avatar" src="{{userInfo.avatarUrl || '/assets/images/default-avatar.png'}}" mode="aspectFill"></image>
    </view>
    <view class="user-info">
      <view class="nickname">{{userInfo.nickname || '微信用户'}}</view>
      <view class="user-id">ID: {{userInfo.id || '--'}}</view>
    </view>
  </view>

  <!-- 快捷功能 -->
  <view class="card menu-card">
    <view class="menu-item" bindtap="goToAllTasks">
      <view class="menu-icon">📋</view>
      <view class="menu-text">全部历史任务</view>
      <view class="menu-arrow">></view>
    </view>
    <view class="menu-divider"></view>
    <view class="menu-item">
      <view class="menu-icon">⚙️</view>
      <view class="menu-text">系统设置</view>
      <view class="menu-arrow">></view>
    </view>
  </view>

  <!-- 最近任务 -->
  <view class="section-header">
    <view class="section-title">最近分析任务</view>
    <view class="more-link" bindtap="goToAllTasks">查看全部 ></view>
  </view>
  
  <view class="task-list" wx:if="{{historyTasks.length > 0}}">
    <view 
      class="card task-card" 
      wx:for="{{historyTasks}}" 
      wx:key="id"
      data-id="{{item.id}}"
      bindtap="goToTaskDetail"
    >
      <view class="task-header">
        <view class="task-no">{{item.taskNo}}</view>
        <view class="task-status {{item.taskStatus === 'SUCCESS' ? 'success' : (item.taskStatus === 'FAILED' ? 'error' : 'processing')}}">
          {{item.taskStatus === 'SUCCESS' ? '已完成' : (item.taskStatus === 'FAILED' ? '失败' : '分析中')}}
        </view>
      </view>
      <view class="task-body">
        <view class="task-type">{{item.taskType === 'SINGLE' ? '单样本分析' : '对比分析'}}</view>
        <view class="task-samples">
          <text class="sample-tag">{{item.sampleCode}}</text>
          <text class="vs-text" wx:if="{{item.taskType === 'COMPARE'}}">VS</text>
          <text class="sample-tag" wx:if="{{item.taskType === 'COMPARE'}}">{{item.compareSampleCode}}</text>
        </view>
      </view>
      <view class="task-footer">
        <text class="task-time">{{item.formattedDate}}</text>
      </view>
    </view>
  </view>
  
  <view class="empty-state" wx:elif="{{!loading}}">
    <text>暂无分析任务</text>
  </view>
</view>
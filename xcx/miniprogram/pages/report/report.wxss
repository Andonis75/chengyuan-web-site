.container {
  padding-bottom: 140rpx;
}

.report-header {
  padding: 40rpx 32rpx;
  background-color: #fff;
  margin-bottom: 24rpx;
}

.report-title {
  font-size: 40rpx;
  font-weight: bold;
  color: var(--text-main);
  margin-bottom: 16rpx;
}

.report-meta {
  font-size: 24rpx;
  color: var(--text-muted);
}

.content-card {
  min-height: 0;
}

.hero-card {
  background: linear-gradient(135deg, #FFF8F0 0%, #FFF3E0 100%);
  border: 2rpx solid rgba(255, 140, 0, 0.15);
}

.hero-top {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.hero-grade {
  font-size: 72rpx;
  font-weight: 800;
  line-height: 1;
  color: var(--primary-color);
}

.hero-label {
  margin-top: 10rpx;
  font-size: 28rpx;
  color: var(--text-secondary);
}

.hero-score {
  font-size: 34rpx;
  font-weight: 700;
  color: var(--text-main);
}

.hero-summary {
  font-size: 28rpx;
  line-height: 1.7;
  color: var(--text-secondary);
}

.info-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 14rpx 0;
  font-size: 28rpx;
}

.info-label {
  color: var(--text-secondary);
}

.info-value {
  color: var(--text-main);
  font-weight: 600;
}

.info-value.strong {
  color: var(--primary-color);
}

.metrics-card {
  padding: 16rpx 28rpx;
}

.metric-item {
  background: #F8FAFC;
  border-radius: 18rpx;
  padding: 24rpx;
  margin: 20rpx 0;
}

.metric-head {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.metric-name {
  font-size: 30rpx;
  font-weight: 700;
  color: var(--text-main);
}

.metric-status {
  font-size: 24rpx;
  border-radius: 999rpx;
  padding: 8rpx 18rpx;
}

.metric-status.excellent {
  color: var(--success-color);
  background: var(--success-light);
}

.metric-status.good {
  color: var(--primary-color);
  background: var(--primary-light);
}

.metric-status.attention {
  color: var(--warning-color);
  background: #FFF4F1;
}

.metric-value-row {
  display: flex;
  align-items: baseline;
  gap: 8rpx;
  margin-bottom: 10rpx;
}

.metric-value {
  font-size: 44rpx;
  font-weight: 800;
  color: var(--primary-color);
}

.metric-unit,
.metric-range {
  font-size: 24rpx;
  color: var(--text-muted);
}

.metric-comment {
  margin-top: 14rpx;
  font-size: 26rpx;
  color: var(--text-secondary);
  line-height: 1.6;
}

.report-content {
  font-size: 28rpx;
  color: var(--text-main);
  line-height: 1.8;
  white-space: pre-wrap;
}

.advice-item {
  display: flex;
  align-items: flex-start;
  gap: 16rpx;
  margin-bottom: 20rpx;
}

.advice-item:last-child {
  margin-bottom: 0;
}

.advice-dot {
  width: 14rpx;
  height: 14rpx;
  border-radius: 7rpx;
  background: var(--primary-color);
  margin-top: 14rpx;
  flex-shrink: 0;
}

.advice-text {
  flex: 1;
  font-size: 28rpx;
  color: var(--text-secondary);
  line-height: 1.7;
}

.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  height: 120rpx;
  background-color: #fff;
  display: flex;
  align-items: center;
  padding: 0 32rpx;
  box-shadow: 0 -4rpx 16rpx rgba(0, 0, 0, 0.05);
  z-index: 100;
}

.btn-primary {
  width: 100%;
  height: 80rpx;
  line-height: 80rpx;
  background: linear-gradient(90deg, var(--primary-color), var(--secondary-color));
  color: #fff;
  border-radius: 40rpx;
  font-size: 32rpx;
  font-weight: bold;
  text-align: center;
}

.btn-primary[disabled] {
  background: #CCCCCC;
  color: #FFFFFF;
}

.loading-state {
  text-align: center;
  padding: 100rpx 0;
  color: var(--text-muted);
}

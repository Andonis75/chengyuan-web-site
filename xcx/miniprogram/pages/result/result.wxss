.container {
  padding-bottom: 140rpx;
}

.summary-card {
  background: linear-gradient(135deg, #FFF8F0 0%, #FFF3E0 100%);
  border: 2rpx solid rgba(255, 140, 0, 0.15);
  position: relative;
  overflow: hidden;
  padding: 40rpx 32rpx;
}

.summary-card::after {
  content: '';
  position: absolute;
  top: -20rpx;
  right: -20rpx;
  width: 120rpx;
  height: 120rpx;
  background: radial-gradient(circle, rgba(255,140,0,0.1) 0%, rgba(255,140,0,0) 70%);
  border-radius: 50%;
}

.summary-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.summary-title {
  font-size: 34rpx;
  font-weight: 700;
  color: var(--primary-color);
  display: flex;
  align-items: center;
}

.summary-title::before {
  content: '✨';
  margin-right: 12rpx;
  font-size: 36rpx;
}

.provider-tag {
  font-size: 22rpx;
  color: var(--text-secondary);
  background-color: rgba(255, 255, 255, 0.8);
  padding: 6rpx 16rpx;
  border-radius: 12rpx;
  font-weight: 500;
}

.summary-content {
  font-size: 30rpx;
  color: var(--text-main);
  line-height: 1.6;
  letter-spacing: 1rpx;
}

.origin-result {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 0;
  background: #F8FAFC;
  border-radius: 16rpx;
  margin: 16rpx 0;
  padding: 32rpx;
}

.origin-name {
  font-size: 48rpx;
  font-weight: 800;
  color: var(--primary-color);
  letter-spacing: 2rpx;
}

.confidence-wrap {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
}

.confidence-label {
  font-size: 26rpx;
  color: var(--text-secondary);
  margin-bottom: 8rpx;
  font-weight: 500;
}

.confidence-value {
  font-size: 40rpx;
  font-weight: 700;
  color: var(--text-main);
  font-family: 'DIN Alternate', sans-serif;
}

.grade-card {
  padding: 36rpx 32rpx;
}

.grade-top {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.grade-level {
  font-size: 68rpx;
  line-height: 1;
  font-weight: 800;
  color: var(--primary-color);
}

.grade-label {
  margin-top: 10rpx;
  font-size: 26rpx;
  color: var(--text-secondary);
}

.grade-score {
  font-size: 34rpx;
  font-weight: 700;
  color: var(--text-main);
}

.grade-summary {
  font-size: 28rpx;
  line-height: 1.7;
  color: var(--text-secondary);
}

.metric-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 24rpx;
}

.metric-item {
  background-color: #F8FAFC;
  padding: 32rpx 24rpx;
  border-radius: 16rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  transition: transform 0.3s;
}

.metric-item:active {
  transform: scale(0.98);
}

.metric-value {
  font-size: 44rpx;
  font-weight: 700;
  color: var(--primary-color);
  margin-bottom: 12rpx;
  font-family: 'DIN Alternate', sans-serif;
}

.metric-label {
  font-size: 26rpx;
  color: var(--text-secondary);
  font-weight: 500;
}

.metric-range {
  margin-top: 10rpx;
  font-size: 22rpx;
  color: var(--text-muted);
}

.sample-card {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
  padding: 32rpx;
}

.sample-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  font-size: 30rpx;
  padding: 12rpx 0;
}

.sample-label {
  color: var(--text-secondary);
  font-weight: 500;
}

.sample-value {
  color: var(--text-main);
  font-weight: 600;
}

.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  height: 140rpx;
  background-color: rgba(255, 255, 255, 0.95);
  backdrop-filter: blur(10px);
  display: flex;
  align-items: center;
  padding: 0 40rpx;
  box-shadow: 0 -4rpx 24rpx rgba(0, 0, 0, 0.06);
  z-index: 100;
  padding-bottom: env(safe-area-inset-bottom);
}

.btn-primary {
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  background: var(--primary-gradient);
  color: #fff;
  border-radius: 44rpx;
  font-size: 34rpx;
  font-weight: 600;
  text-align: center;
  box-shadow: 0 8rpx 20rpx rgba(255, 140, 0, 0.3);
  transition: all 0.3s;
}

.btn-primary:active {
  transform: scale(0.98);
  box-shadow: 0 4rpx 10rpx rgba(255, 140, 0, 0.2);
}

.loading-state {
  text-align: center;
  padding: 100rpx 0;
  color: var(--text-muted);
}

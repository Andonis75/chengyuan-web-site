.container {
  padding-bottom: 140rpx;
}

.form-card {
  padding: 0 32rpx;
}

.form-item {
  display: flex;
  flex-direction: column;
  padding: 24rpx 0;
  border-bottom: 2rpx solid #F0F0F0;
}

.form-item.no-border {
  border-bottom: none;
}

.form-label {
  font-size: 28rpx;
  color: var(--text-main);
  margin-bottom: 16rpx;
}

.form-label.required::after {
  content: '*';
  color: var(--warning-color);
  margin-left: 8rpx;
}

.form-input {
  height: 60rpx;
  font-size: 32rpx;
  color: var(--text-main);
}

.picker-value {
  height: 60rpx;
  line-height: 60rpx;
  font-size: 32rpx;
  color: var(--text-main);
}

.picker-value.placeholder {
  color: #999;
}

.form-textarea {
  width: 100%;
  height: 160rpx;
  font-size: 28rpx;
  color: var(--text-main);
  background-color: var(--bg-color);
  padding: 16rpx;
  border-radius: 8rpx;
  box-sizing: border-box;
}

.file-card {
  padding: 32rpx;
}

.file-list {
  margin-bottom: 24rpx;
}

.file-item {
  display: flex;
  align-items: center;
  background-color: var(--bg-color);
  padding: 20rpx;
  border-radius: 12rpx;
  margin-bottom: 16rpx;
}

.file-icon {
  font-size: 48rpx;
  margin-right: 24rpx;
}

.file-info {
  flex: 1;
  overflow: hidden;
}

.file-name {
  font-size: 28rpx;
  color: var(--text-main);
  margin-bottom: 8rpx;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.file-status {
  font-size: 24rpx;
}

.file-status.pending { color: var(--text-muted); }
.file-status.uploading { color: var(--primary-color); }
.file-status.success { color: var(--success-color); }
.file-status.error { color: var(--warning-color); }

.file-remove {
  width: 60rpx;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: var(--text-muted);
  font-size: 32rpx;
}

.upload-btn {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  height: 200rpx;
  border: 2rpx dashed #CCCCCC;
  border-radius: 12rpx;
  background-color: #FAFAFA;
}

.upload-icon {
  font-size: 60rpx;
  color: #999;
  margin-bottom: 8rpx;
  line-height: 1;
}

.upload-text {
  font-size: 28rpx;
  color: var(--text-main);
  margin-bottom: 8rpx;
}

.upload-hint {
  font-size: 24rpx;
  color: var(--text-muted);
}

.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  height: 120rpx;
  background-color: #fff;
  display: flex;
  align-items: center;
  padding: 0 32rpx;
  box-shadow: 0 -4rpx 16rpx rgba(0, 0, 0, 0.05);
  z-index: 100;
}

.btn-primary {
  width: 100%;
  height: 80rpx;
  line-height: 80rpx;
  background: linear-gradient(90deg, var(--primary-color), var(--secondary-color));
  color: #fff;
  border-radius: 40rpx;
  font-size: 32rpx;
  font-weight: bold;
  text-align: center;
}

.btn-primary.disabled {
  background: #CCCCCC;
  color: #FFFFFF;
}